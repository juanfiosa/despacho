{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "20mb" }
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "public/demos/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)",    "dest": "/api/index.py" },
    { "src": "/demos/(.*)", "dest": "/public/demos/$1" },
    { "src": "/(.*)",       "dest": "/index.html" }
  ]
}
